DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME
SECRET_KEY=change-me
DEBUG=1
ALLOWED_HOSTS=localhost,127.0.0.1,.onrender.com
CORS_ALLOWED_ORIGINS=http://localhost:3000
CSRF_TRUSTED_ORIGINS=
# only for local development do not use this in production
COOKIE_SECURE=0
# SameSite policy for session/CSRF cookies. Use "Lax" for same-site dev.
# When the SPA is on a different origin than the API (e.g. localhost:3000
# talking to aniflow-36tm.onrender.com) set this to "None" *and* enable
# COOKIE_SECURE=1 so browsers will send the cookie cross-site.
COOKIE_SAMESITE=Lax
# Default destination after a successful AniList login when no ?next=
# parameter is supplied by the SPA.
FRONTEND_URL=http://localhost:3000
# Comma-separated list of origins (scheme://host[:port]) the OAuth callback
# is allowed to redirect back to. Leave unset to default to FRONTEND_URL +
# CORS_ALLOWED_ORIGINS.
FRONTEND_ALLOWED_REDIRECT_ORIGINS=
# only for local development do not use this in production
ANILIST_REDIRECT_URI=http://localhost:3000/auth/anilist/callback/
# only for local development do not use this in production
ANILIST_CLIENT_ID=change-me
# only for local development do not use this in production
ANILIST_CLIENT_SECRET=change-me